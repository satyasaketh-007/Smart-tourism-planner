# Copy this file to server/.env and fill in your values

# MongoDB Atlas connection string
# Get this from: cloud.mongodb.com → Your Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/smart_tour_planner?retryWrites=true&w=majority

# Express server port
PORT=5000

# JWT secret (any long random string)
JWT_SECRET=your_secret_key_here
